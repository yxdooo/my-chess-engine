{
    "manifest_version": 3,
    "name": "Aether Chess Engine",
    "version": "2.1.0",
    "description": "A highly optimized, multi-threaded WebAssembly (Rust) chess engine. Real-time best-move arrows directly on Chess.com and Lichess.",
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "offscreen",
        "tabs"
    ],
    "offscreen": {
        "reasons": ["WORKERS"],
        "justification": "Spawn Web Workers to run the WASM chess engine across multiple CPU cores (Lazy SMP).",
        "urls": ["offscreen.html"]
    },
    "host_permissions": [
        "*://*.chess.com/*",
        "*://*.lichess.org/*",
        "*://*.lichess.ovh/*",
        "*://*.tablebase.lichess.ovh/*",
        "*://*.explorer.lichess.ovh/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "cross_origin_embedder_policy": {
        "value": "require-corp"
    },
    "cross_origin_opener_policy": {
        "value": "same-origin"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.chess.com/*",
                "*://*.lichess.org/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        },
        {
            "matches": [
                "*://*.chess.com/*",
                "*://*.lichess.org/*"
            ],
            "js": [
                "inject.js"
            ],
            "world": "MAIN"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "engine_wasm_bg.wasm",
                "pkg/*",
                "icon.png"
            ],
            "matches": [
                "*://*.chess.com/*",
                "*://*.lichess.org/*"
            ]
        }
    ]
}
